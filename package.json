{
  "name": "@paraphraser-humanizer/root",
  "version": "0.1.0",
  "private": true,
  "description": "Writer's Coach + Human-Typer Extension - Production-ready monorepo",
  "keywords": [
    "paraphraser",
    "writing-coach",
    "chrome-extension",
    "typescript",
    "monorepo"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter @paraphraser-humanizer/api dev\" \"pnpm --filter @paraphraser-humanizer/web dev\" \"pnpm --filter @paraphraser-humanizer/extension dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "seed": "pnpm --filter @paraphraser-humanizer/api seed",
    "start": "concurrently \"pnpm --filter @paraphraser-humanizer/api start\" \"pnpm --filter @paraphraser-humanizer/web start\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.18.0"
}
